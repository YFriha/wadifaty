{
    "builds": [
        {
            "src": "frontend/dist/**",
            "use": "@vercel/static"
        },
        {
            "src": "api.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.12"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api.py"
        },
        {
            "src": "/admin/(.*)",
            "dest": "api.py"
        },
        {
            "src": "/assets/(.*)",
            "dest": "frontend/dist/assets/$1"
        },
        {
            "src": "/favicon.svg",
            "dest": "frontend/dist/favicon.svg"
        },
        {
            "src": "/icons.svg",
            "dest": "frontend/dist/icons.svg"
        },
        {
            "src": "/(.*)",
            "dest": "frontend/dist/index.html"
        }
    ]
}