{
    "builds": [
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        },
        {
            "src": "api.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.12"
            }
        }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "api.py" },
        { "src": "/admin/(.*)", "dest": "api.py" },
        { "src": "/assets/(.*)", "dest": "frontend/assets/$1" },
        { "src": "/favicon.svg", "dest": "frontend/favicon.svg" },
        { "src": "/icons.svg", "dest": "frontend/icons.svg" },
        { "src": "/(.*)", "dest": "frontend/index.html" }
    ]
}